// Everest Voucher EC – Prisma Schema
// Mapping với schema trong backend/src/db/init_db.sql

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============= ENUMS =============
enum UserRole {
  Admin
  Customer
  Partner_Owner
  Partner_Cashier
}

enum AccountStatus {
  Active
  Inactive
  Banned
}

enum PartnerStatus {
  Pending
  Approved
  Rejected
}

enum BannerStatus {
  Visible
  Hidden
}

enum PolicyType {
  Terms_Of_Service
  Privacy_Policy
  Refund_Policy
}

enum VoucherApprovalStatus {
  Draft
  Pending
  Approved
  Rejected
}

enum VoucherDisplayStatus {
  Visible
  Hidden
}

enum PaymentStatus {
  Pending
  Paid
  Cancelled
}

enum VoucherUsageStatus {
  Unused
  Used
  Expired
  Locked
}

// ============= TÀI KHOẢN =============
model User {
  userId       String         @id @default(uuid()) @map("user_id") @db.Uuid
  email        String         @unique @db.VarChar(100)
  phoneNumber  String?        @unique @map("phone_number") @db.VarChar(15)
  passwordHash String?        @map("password_hash") @db.VarChar(255)
  fullName     String         @map("full_name") @db.VarChar(100)
  role         UserRole       @default(Customer)
  status       AccountStatus  @default(Active)
  partnerId    Int?           @map("partner_id")
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  partner     Partner?       @relation(fields: [partnerId], references: [partnerId], onDelete: SetNull)
  branch      Branch?        @relation("BranchCashier")
  cartItems   CartItem[]
  orders      Order[]
  reviews     Review[]
  logs        SystemLog[]

  @@map("users")
}

model Partner {
  partnerId          Int           @id @default(autoincrement()) @map("partner_id")
  companyName        String        @map("company_name") @db.VarChar(150)
  taxCode            String        @unique @map("tax_code") @db.VarChar(20)
  businessLicenseUrl String?       @map("business_license_url") @db.VarChar(255)
  status             PartnerStatus @default(Pending)
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  users    User[]
  branches Branch[]
  vouchers Voucher[]

  @@map("partners")
}

model Branch {
  branchId    Int       @id @default(autoincrement()) @map("branch_id")
  partnerId   Int       @map("partner_id")
  cashierId   String?   @unique @map("cashier_id") @db.Uuid
  branchName  String    @map("branch_name") @db.VarChar(150)
  address     String    @db.VarChar(255)
  phoneNumber String?   @map("phone_number") @db.VarChar(15)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  partner        Partner          @relation(fields: [partnerId], references: [partnerId], onDelete: Cascade)
  cashier        User?            @relation("BranchCashier", fields: [cashierId], references: [userId], onDelete: SetNull)
  voucherBranches VoucherBranch[]
  issuedVouchers IssuedVoucher[]  @relation("IssuedAtBranch")

  @@map("branches")
}

// ============= SẢN PHẨM =============
model Category {
  categoryId   Int       @id @default(autoincrement()) @map("category_id")
  categoryName String    @map("category_name") @db.VarChar(100)
  description  String?

  vouchers Voucher[]

  @@map("categories")
}

model Banner {
  bannerId     Int          @id @default(autoincrement()) @map("banner_id")
  title        String       @db.VarChar(150)
  imageUrl     String       @map("image_url") @db.VarChar(255)
  targetUrl    String?      @map("target_url") @db.VarChar(255)
  displayOrder Int          @default(0) @map("display_order")
  status       BannerStatus @default(Visible)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz

  @@map("banners")
}

model Policy {
  policyId   Int        @id @default(autoincrement()) @map("policy_id")
  policyType PolicyType @unique @map("policy_type")
  content    String
  updatedAt  DateTime   @default(now()) @map("updated_at") @db.Timestamptz

  @@map("policies")
}

model Voucher {
  voucherId         Int                    @id @default(autoincrement()) @map("voucher_id")
  partnerId         Int                    @map("partner_id")
  categoryId        Int?                   @map("category_id")
  title             String                 @db.VarChar(255)
  description       String?
  originalPrice     Decimal                @map("original_price") @db.Decimal(12, 2)
  salePrice         Decimal                @map("sale_price") @db.Decimal(12, 2)
  totalQuantity     Int                    @map("total_quantity")
  availableQuantity Int                    @map("available_quantity")
  imageUrl          String?                @map("image_url") @db.VarChar(255)
  startDate         DateTime               @map("start_date") @db.Timestamptz
  endDate           DateTime               @map("end_date") @db.Timestamptz
  expiryDays        Int                    @map("expiry_days")
  approvalStatus    VoucherApprovalStatus  @default(Draft) @map("approval_status")
  displayStatus     VoucherDisplayStatus   @default(Hidden) @map("display_status")
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  partner        Partner         @relation(fields: [partnerId], references: [partnerId], onDelete: Cascade)
  category       Category?       @relation(fields: [categoryId], references: [categoryId], onDelete: SetNull)
  voucherBranches VoucherBranch[]
  cartItems      CartItem[]
  orderItems     OrderItem[]
  reviews        Review[]

  @@map("vouchers")
}

model VoucherBranch {
  voucherId Int @map("voucher_id")
  branchId  Int @map("branch_id")

  voucher Voucher @relation(fields: [voucherId], references: [voucherId], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [branchId], onDelete: Cascade)

  @@id([voucherId, branchId])
  @@map("voucher_branches")
}

// ============= GIAO DỊCH =============
model CartItem {
  cartItemId Int      @id @default(autoincrement()) @map("cart_item_id")
  customerId String   @map("customer_id") @db.Uuid
  voucherId  Int      @map("voucher_id")
  quantity   Int
  addedAt    DateTime @default(now()) @map("added_at") @db.Timestamptz

  customer User    @relation(fields: [customerId], references: [userId], onDelete: Cascade)
  voucher  Voucher @relation(fields: [voucherId], references: [voucherId], onDelete: Cascade)

  @@unique([customerId, voucherId])
  @@map("cart_items")
}

model Order {
  orderId       Int           @id @default(autoincrement()) @map("order_id")
  customerId    String        @map("customer_id") @db.Uuid
  totalAmount   Decimal       @map("total_amount") @db.Decimal(12, 2)
  paymentMethod String?       @map("payment_method") @db.VarChar(50)
  paymentStatus PaymentStatus @default(Pending) @map("payment_status")
  isGift        Boolean       @default(false) @map("is_gift")
  receiverEmail String?       @map("receiver_email") @db.VarChar(100)
  giftMessage   String?       @map("gift_message")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  customer    User            @relation(fields: [customerId], references: [userId], onDelete: Restrict)
  orderItems  OrderItem[]

  @@map("orders")
}

model OrderItem {
  orderItemId Int     @id @default(autoincrement()) @map("order_item_id")
  orderId     Int     @map("order_id")
  voucherId   Int     @map("voucher_id")
  quantity    Int
  price       Decimal @db.Decimal(12, 2)

  order          Order           @relation(fields: [orderId], references: [orderId], onDelete: Cascade)
  voucher        Voucher         @relation(fields: [voucherId], references: [voucherId], onDelete: Restrict)
  issuedVouchers IssuedVoucher[]

  @@map("order_items")
}

model IssuedVoucher {
  issuedVoucherId Int                 @id @default(autoincrement()) @map("issued_voucher_id")
  orderItemId     Int                 @map("order_item_id")
  voucherCode     String              @unique @map("voucher_code") @db.VarChar(50)
  status          VoucherUsageStatus  @default(Unused)
  validFrom       DateTime            @map("valid_from") @db.Timestamptz
  validTo         DateTime            @map("valid_to") @db.Timestamptz
  usedAt          DateTime?           @map("used_at") @db.Timestamptz
  usedAtBranchId  Int?                @map("used_at_branch_id")

  orderItem    OrderItem @relation(fields: [orderItemId], references: [orderItemId], onDelete: Cascade)
  usedAtBranch Branch?   @relation("IssuedAtBranch", fields: [usedAtBranchId], references: [branchId], onDelete: SetNull)
  reviews      Review[]

  @@map("issued_vouchers")
}

// ============= TƯƠNG TÁC =============
model Review {
  reviewId        Int      @id @default(autoincrement()) @map("review_id")
  customerId      String   @map("customer_id") @db.Uuid
  voucherId       Int      @map("voucher_id")
  issuedVoucherId Int?     @map("issued_voucher_id")
  rating          Int
  comment         String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  customer      User           @relation(fields: [customerId], references: [userId], onDelete: Cascade)
  voucher       Voucher        @relation(fields: [voucherId], references: [voucherId], onDelete: Cascade)
  issuedVoucher IssuedVoucher? @relation(fields: [issuedVoucherId], references: [issuedVoucherId], onDelete: SetNull)

  @@map("reviews")
}

model SystemLog {
  logId       BigInt   @id @default(autoincrement()) @map("log_id")
  actorId     String?  @map("actor_id") @db.Uuid
  actorRole   String?  @map("actor_role") @db.VarChar(50)
  action      String   @db.VarChar(100)
  description String?
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  actor User? @relation(fields: [actorId], references: [userId], onDelete: SetNull)

  @@map("system_logs")
}